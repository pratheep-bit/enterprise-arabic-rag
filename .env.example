# ============================================================
# Arabic Document Q&A RAG System — Environment Variables
# ============================================================

# --- LLM Configuration ---
# OpenAI API key (required unless OPENROUTER_API_KEY is set)
OPENAI_API_KEY=your-openai-api-key-here

# Optional OpenRouter key. If set, the app uses OpenRouter's OpenAI-compatible API.
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# LLM model to use for question answering
LLM_MODEL=gpt-4o

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# --- Embedding Configuration ---
# HuggingFace embedding model for multilingual support
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# --- Vector Database ---
# Directory for ChromaDB persistent storage
CHROMA_PERSIST_DIR=./chroma_db

# Directory for local runtime metadata
DATA_DIR=./data
DOCUMENT_REGISTRY_PATH=./data/document_registry.json

# --- File Upload ---
# Directory to store uploaded PDFs
UPLOAD_DIR=./uploads

# Maximum upload file size in megabytes
MAX_FILE_SIZE_MB=20

# --- Retrieval Configuration ---
# Number of top chunks to retrieve
TOP_K=5

# Minimum similarity score (0.0–1.0) — chunks below this are discarded
MIN_SIMILARITY_THRESHOLD=0.3

# --- Chunking Configuration ---
# Maximum characters per chunk
CHUNK_SIZE=800

# Overlap between consecutive chunks
CHUNK_OVERLAP=150

# --- Confidence Scoring ---
# Weights for blended confidence (must sum to 1.0)
CONFIDENCE_WEIGHT_LLM=0.6
CONFIDENCE_WEIGHT_RETRIEVAL=0.4

# --- Authentication ---
# Set this to enable API key auth (X-API-Key header required)
# Leave empty to disable auth
# API_AUTH_KEY=your-secret-api-key-here

# --- Rate Limiting ---
# slowapi rate limits per IP
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_ASK=30/minute
RATE_LIMIT_UPLOAD=30/minute

# --- Server Configuration ---
# FastAPI host and port
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated browser origins allowed to call the API
API_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
API_CORS_ALLOW_CREDENTIALS=false

# Streamlit frontend target API URL
API_BASE_URL=http://localhost:8000

# --- Observability ---
# Log format: "json" for structured logging, "text" for human-readable
LOG_FORMAT=json
